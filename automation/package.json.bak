{
  "name": "playright",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:3001": "cross-env PORT=3001 node server.js",
    "dev": "nodemon server.js",
    "dev:3001": "cross-env PORT=3001 nodemon server.js",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "install-browsers": "playwright install",
    "codegen": "playwright codegen",
    "codegen:target": "playwright codegen --target=playwright-test"
  },
  "keywords": [
    "playwright",
    "testing",
    "automation",
    "web"
  ],
  "author": "",
  "license": "ISC",
  "description": "Proyecto de pruebas automatizadas con Playwright y panel de control web",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.0.12",
    "@types/xlsx": "^0.0.36",
    "cross-env": "^10.1.0"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "xlsx": "^0.18.5"
  }
}
